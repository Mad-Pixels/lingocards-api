{
  "policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:UpdateItem",
          "dynamodb:ListTables"
        ],
        "Resource": "${logs_table_arn}"
      }
    ]
  },
  "memory_size": 128,
  "timeout": 2,
  "envs": {}
}